# LLM Provider
# "anthropic" (default) or "openai". The model factory in
# src/burry/models.py swaps providers off this single flag.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Alpaca (paper trading by default)
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...
ALPACA_PAPER=true

# Market Data
FINNHUB_API_KEY=...

# Massive (optional extra research step — set ENABLE_MASSIVE=true to add it
# as a third research agent alongside Technical & Macro)
ENABLE_MASSIVE=false
MASSIVE_API_KEY=...

# Risk Limits (hardcoded fallbacks live in src/burry/risk/limits.py)
MAX_POSITION_PCT=0.10          # max single position as fraction of equity
MAX_NOTIONAL_PER_ORDER=10000   # max $ per order
MAX_OPEN_POSITIONS=15
